# Kopieer dit bestand naar .env.local en vul de waarden in

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=jouw_wachtwoord_hier

# Genereer met: openssl rand -base64 32
JWT_SECRET=jouw_jwt_secret_hier

# Vercel Blob token — kopieer uit Vercel dashboard → Storage → Blob store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
